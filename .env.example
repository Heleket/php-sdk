# Copy this file to .env and fill in your Heleket credentials.
# See https://doc.heleket.com/general/getting-api-keys for how to obtain these.

# Merchant UUID — found in dash.heleket.com → Settings.
HELEKET_MERCHANT_ID=

# Payment API key — used for /v1/payment/* endpoints and payment webhooks.
HELEKET_PAYMENT_KEY=

# Payout API key — used for /v1/payout/* endpoints and payout webhooks.
# Generating a new key locks withdrawals for 24h.
HELEKET_PAYOUT_KEY=

# Set to 1 to dump every HTTP request/response to stderr.
HELEKET_DEBUG=0

# Optional override of the API base URL (defaults to https://api.heleket.com).
# HELEKET_BASE_URL=https://api.heleket.com
